    "help_keywords_title": {
        "message": "キーワード検索（AND）"
    },
    "help_keywords_desc": {
        "message": "複数のキーワードを<strong>全て含む</strong>ポストを検索します。スペースで区切ります。"
    },
    "help_keywords_example": {
        "message": "例: <strong>プログラミング AI</strong> → 「プログラミング」と「AI」の両方を含むポスト"
    },
    "help_exact_title": {
        "message": "完全一致検索"
    },
    "help_exact_desc": {
        "message": "指定したフレーズに<strong>完全一致</strong>するポストを検索します。語順も一致する必要があります。"
    },
    "help_exact_example": {
        "message": "例: <strong>\"機械学習 入門\"</strong> → 「機械学習 入門」という並びを含むポスト"
    },
    "help_or_title": {
        "message": "OR検索"
    },
    "help_or_desc": {
        "message": "指定したキーワードの<strong>いずれか</strong>を含むポストを検索します。カンマで区切って入力してください。"
    },
    "help_or_example": {
        "message": "例: <strong>Python,JavaScript</strong> → 「Python OR JavaScript」に変換"
    },
    "help_exclude_title": {
        "message": "除外検索"
    },
    "help_exclude_desc": {
        "message": "指定したキーワードを<strong>含まない</strong>ポストに絞り込みます。カンマで区切って複数指定可能。"
    },
    "help_exclude_example": {
        "message": "例: <strong>広告,PR</strong> → 「-広告 -PR」に変換"
    },
    "help_hashtag_title": {
        "message": "ハッシュタグ検索"
    },
    "help_hashtag_desc": {
        "message": "特定の<strong>ハッシュタグ</strong>を含むポストを検索します。#は自動的に付与されます。"
    },
    "help_hashtag_example": {
        "message": "例: <strong>AI</strong> → 「#AI」を含むポスト"
    },
    "help_cashtag_title": {
        "message": "キャッシュタグ検索"
    },
    "help_cashtag_desc": {
        "message": "<strong>株式ティッカーシンボル</strong>など、$記号で始まるタグを検索します。$は自動付与。"
    },
    "help_cashtag_example": {
        "message": "例: <strong>TSLA</strong> → 「$TSLA」を含むポスト"
    },
    "help_from_title": {
        "message": "投稿者検索"
    },
    "help_from_desc": {
        "message": "特定のユーザーが<strong>投稿した</strong>ポストのみを検索します。@は不要です。"
    },
    "help_from_example": {
        "message": "例: <strong>elonmusk</strong> → @elonmuskのポストのみ"
    },
    "help_to_title": {
        "message": "宛先検索"
    },
    "help_to_desc": {
        "message": "特定のユーザーに<strong>返信した</strong>ポストを検索します。"
    },
    "help_to_example": {
        "message": "例: <strong>elonmusk</strong> → @elonmusk宛てのリプライ"
    },
    "help_mention_title": {
        "message": "メンション検索"
    },
    "help_mention_desc": {
        "message": "特定のユーザーが<strong>言及された</strong>ポストを検索します。"
    },
    "help_mention_example": {
        "message": "例: <strong>NASA</strong> → @NASAが言及されたポスト"
    },
    "help_follows_title": {
        "message": "フォロー中のみ"
    },
    "help_follows_desc": {
        "message": "自分が<strong>フォローしている</strong>アカウントのポストのみに絞り込みます。"
    },
    "help_follows_example": {
        "message": "※ ログイン中のアカウントのフォロー対象が反映されます"
